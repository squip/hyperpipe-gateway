{
  "name": "hyperpipe-public-gateway",
  "version": "0.1.0",
  "description": "Public Hyperswarm gateway for Hyperpipe relays",
  "private": true,
  "type": "module",
  "main": "src/index.mjs",
  "homepage": "https://hyperpipe.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/squip/hyperpipe.git",
    "directory": "hyperpipe-gateway"
  },
  "bugs": {
    "url": "https://github.com/squip/hyperpipe/issues"
  },
  "scripts": {
    "dev": "node --env-file=.env.local src/index.mjs",
    "start": "node src/index.mjs",
    "lint": "eslint src --ext .js,.mjs",
    "test": "node --test",
    "blind-peer:status": "node ./bin/blind-peer-status.mjs",
    "pack:check": "npm pack --dry-run"
  },
  "files": [
    "bin/**",
    "src/**",
    "Dockerfile",
    "README.md",
    "package.json"
  ],
  "dependencies": {
    "@hyperpipe/bridge": "file:../hyperpipe-bridge",
    "@noble/curves": "^1.2.0",
    "@nostr-dev-kit/ndk": "^3.0.3",
    "@nostr-dev-kit/wot": "^1.0.0",
    "b4a": "^1.6.4",
    "blind-peer": "^2.9.2",
    "blind-peer-encodings": "^3.1.0",
    "compact-encoding": "^2.12.0",
    "corestore": "^6.14.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.0.0",
    "hyperbee": "^2.13.4",
    "hypercore-crypto": "^3.5.0",
    "hypercore-id-encoding": "^1.3.0",
    "hyperswarm": "^4.14.0",
    "pino": "^9.1.0",
    "pino-http": "^9.0.0",
    "prom-client": "^15.1.0",
    "redis": "^4.6.13",
    "ws": "^8.18.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  }
}
