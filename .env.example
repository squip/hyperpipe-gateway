# Example configuration for the Hyperpipe public gateway
PORT=4430
GATEWAY_PUBLIC_URL=https://gateway.example.com

GATEWAY_TLS_ENABLED=false
GATEWAY_TLS_KEY=./certs/key.pem
GATEWAY_TLS_CERT=./certs/cert.pem

GATEWAY_METRICS_ENABLED=true
GATEWAY_METRICS_PATH=/metrics

GATEWAY_REGISTRATION_SECRET=change-me
GATEWAY_REGISTRATION_REDIS=redis://redis:6379
GATEWAY_REGISTRATION_REDIS_PREFIX=gateway:registrations:
GATEWAY_REGISTRATION_TTL=300
GATEWAY_DEFAULT_TOKEN_TTL=3600
GATEWAY_TOKEN_REFRESH_WINDOW=300

GATEWAY_RATELIMIT_ENABLED=true
GATEWAY_RATELIMIT_WINDOW=60
GATEWAY_RATELIMIT_MAX=120

GATEWAY_DISCOVERY_ENABLED=true
GATEWAY_DISCOVERY_DISPLAY_NAME=Example Gateway
GATEWAY_DISCOVERY_REGION=
GATEWAY_DISCOVERY_KEY_SEED=<stable-seed>
GATEWAY_NOSTR_DISCOVERY_ENABLED=true
GATEWAY_NOSTR_DISCOVERY_RELAYS=wss://relay.damus.io/,wss://relay.primal.net/,wss://nos.lol/

GATEWAY_AUTH_HOST_POLICY=allowlist+wot
GATEWAY_AUTH_MEMBER_DELEGATION=all-members
GATEWAY_AUTH_OPERATOR_PUBKEY=<64-char-hex>
GATEWAY_AUTH_OPERATOR_ATTESTATION_FILE=/app/public-gateway/artifacts/operator-attestation.json
GATEWAY_AUTH_WOT_ROOT_PUBKEY=<64-char-hex>
GATEWAY_AUTH_WOT_MAX_DEPTH=2
GATEWAY_AUTH_WOT_MIN_FOLLOWERS_DEPTH2=2
GATEWAY_AUTH_WOT_RELAYS=wss://relay.damus.io/,wss://relay.primal.net/,wss://nos.lol/
GATEWAY_AUTH_WOT_LOAD_TIMEOUT_MS=12000
GATEWAY_AUTH_WOT_REFRESH_MS=600000
GATEWAY_AUTH_ALLOWLIST_PUBKEYS=<64-char-hex>,<64-char-hex>
GATEWAY_AUTH_ALLOWLIST_FILE=/data/config/allowlist.json
GATEWAY_AUTH_ALLOWLIST_REFRESH_MS=5000
GATEWAY_AUTH_BLOCKLIST_PUBKEYS=
GATEWAY_AUTH_BLOCKLIST_FILE=/data/config/blocklist.json
GATEWAY_AUTH_BLOCKLIST_REFRESH_MS=5000
GATEWAY_AUTH_MAX_RELAYS_PER_SPONSOR=100
GATEWAY_AUTH_MAX_MEMBERS_PER_RELAY=500
GATEWAY_AUTH_MAX_OPEN_JOIN_POOL=100
GATEWAY_AUTH_MAX_MIRRORED_BYTES_PER_RELAY=0

GATEWAY_FEATURE_HYPERBEE_RELAY=true
GATEWAY_RELAY_STORAGE=/data/gateway-relay
GATEWAY_RELAY_SEED=<64-char-hex>
GATEWAY_RELAY_ADMIN_PUBLIC_KEY=<64-char-hex>
GATEWAY_RELAY_ADMIN_SECRET_KEY=<128-char-hex>
GATEWAY_RELAY_NAMESPACE=public-gateway-relay
